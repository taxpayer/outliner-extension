{
  "manifest_version": 3,
  "name": "__MSG_appName__",
  "version": "4.1",
  "description": "__MSG_appDesc__",
  "default_locale": "en",
  "author": "Rodrigo Vasconcellos",
  "icons": {
    "16": "assets/outline-logo-16.png",
    "32": "assets/outline-logo-32.png",
    "48": "assets/outline-logo-48.png",
    "128": "assets/outline-logo.png"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "optional_host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_icon": "assets/outline-logo.png",
    "default_title": "Outliner",
    "default_popup": "popup.html"
  },
  "background" : {
    "service_worker": "background.js",
    "type": "module"
  }
}