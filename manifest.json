{
  "manifest_version": 3,
  "name": "Outliner | Improving your reading experience",
  "version": "4.0",
  "description": "A simple one-click tool to improve your reading experience by bypassing common web distractions and paywall overlays.",
  "author": "Rodrigo Vasconcellos",
  "icons": {
    "16": "assets/outline-logo-16.png",
    "32": "assets/outline-logo-32.png",
    "48": "assets/outline-logo-48.png",
    "128": "assets/outline-logo.png"
  },
  "action": {
    "default_icon": "assets/outline-logo.png",
    "default_title": "Outliner"
  },
  "background" : {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ]
}